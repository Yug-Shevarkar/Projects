@model List<ItemProcessorApp.Models.Item>

<h2 class="title">Item Management</h2>

<div class="top-bar">
    <a href="/Item/ProcessedList" class="btn secondary">Processed Items</a>

    <form method="get" class="search-box">
        <input name="search" placeholder="Search weight..." />
        <button class="btn">Search</button>
    </form>

    <a href="/Item/Create" class="btn primary">+ Add Item</a>
</div>

<table class="styled-table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Weight</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Weight</td>
                <td class="actions">
                    <a href="/Item/Edit/@item.Id" class="btn small">Edit</a>
                    <a href="/Item/Delete/@item.Id" class="btn small danger">Delete</a>
                    <a href="/Item/Process/@item.Id" class="btn small success">Process</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<style>
body {
    font-family: Arial, sans-serif;
}

.title {
    text-align: center;
    margin-bottom: 20px;
}

.top-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
}

.search-box input {
    padding: 6px;
    margin-right: 5px;
}

.styled-table {
    width: 100%;
    border-collapse: collapse;
    background: white;
}

.styled-table th,
.styled-table td {
    padding: 10px;
    border: 1px solid #ddd;
    text-align: center;
}

.styled-table th {
    background: #f4f4f4;
}

.actions {
    display: flex;
    justify-content: center;
    gap: 8px;
}

/* Buttons */
.btn {
    padding: 6px 12px;
    text-decoration: none;
    border-radius: 5px;
    color: white;
    background: #3b82f6;
}

.btn.primary {
    background: #2563eb;
}

.btn.secondary {
    background: #6b7280;
}

.btn.small {
    padding: 5px 10px;
    font-size: 12px;
}

.btn.success {
    background: #16a34a;
}

.btn.danger {
    background: #dc2626;
}
</style>