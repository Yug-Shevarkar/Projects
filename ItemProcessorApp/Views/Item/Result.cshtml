@model ItemProcessorApp.Models.Item

<h2 style="text-align:center;">Flow Representation</h2>

<div class="diagram-container">
    <div class="scroll-box">
        <div id="tree"></div>
    </div>
</div>

<div style="text-align:center; margin-top:20px;">
    <a href="/Item" class="btn">Try Again</a>
</div>

<script>
    const data = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));
    const container = document.getElementById("tree");

    function render(node, level = 0) {
        let div = document.createElement("div");
        div.style.marginLeft = (level * 30) + "px";
        div.style.padding = "6px 0";

        let prefix = level === 0 ? "" : "└── ";
        div.innerHTML = `<span class="node">${prefix}${node.Weight}</span>`;

        container.appendChild(div);

        if (node.Children && node.Children.length > 0) {
            node.Children.forEach(child => {
                render(child, level + 1);
            });
        }
    }

    render(data);
</script>

<style>
.diagram-container {
    display: flex;
    justify-content: center;
    margin-top: 20px;
}

.scroll-box {
    width: 100%;
    max-width: 900px;
    height: 600px;
    overflow: auto;
    border: 1px solid #ccc;
    border-radius: 10px;
    background: white;
    padding: 15px;
    font-family: monospace;
}

.node {
    background: #3b82f6;
    color: white;
    padding: 4px 10px;
    border-radius: 6px;
    display: inline-block;
}

#tree div {
    border-left: 2px solid #ddd;
    padding-left: 10px;
}
</style>