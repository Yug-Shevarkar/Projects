@model ItemProcessorApp.Models.Item

<h2 style="text-align:center;">Flow Representation</h2>

<div class="diagram-container">
    <div class="scroll-box">
        <div id="tree"></div>
    </div>
</div>

<div style="text-align:center; margin-top:20px;">
    <a href="/Item" class="btn">Try Again</a>
</div>

<script>
    const data = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));
    const container = document.getElementById("tree");

    function createTree(node) {
        let li = document.createElement("li");
        li.innerHTML = `<span>${node.Weight}</span>`;

        if (node.Children && node.Children.length > 0) {
            let ul = document.createElement("ul");
            node.Children.forEach(child => {
                ul.appendChild(createTree(child));
            });
            li.appendChild(ul);
        }

        return li;
    }

    let rootUl = document.createElement("ul");
    rootUl.appendChild(createTree(data));
    container.appendChild(rootUl);
</script>

<style>
.diagram-container {
    display: flex;
    justify-content: center;
    margin-top: 20px;
}

.scroll-box {
    width: 100%;
    max-width: 900px;
    height: 600px;
    overflow: auto;
    border: 1px solid #ccc;
    border-radius: 10px;
    background: white;
    padding: 20px;
    font-family: monospace;
}

#tree ul {
    padding-left: 20px;
    position: relative;
}

#tree li {
    list-style: none;
    margin: 10px 0;
    position: relative;
}

#tree li::before {
    content: "";
    position: absolute;
    top: -10px;
    left: -10px;
    border-left: 2px solid #999;
    border-bottom: 2px solid #999;
    width: 10px;
    height: 20px;
}

#tree li:last-child::before {
    border-left: 2px solid transparent;
}

#tree span {
    padding: 4px 10px;
    border-radius: 6px;
    background: #f3f4f6;
    display: inline-block;
}
</style>