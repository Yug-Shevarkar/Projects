@{
    ViewData["Title"] = "Item Processor";
}

<div class="container">
    <div class="card">
        <h2>Item Processor</h2>
        <p>Enter item weight to generate child items</p>

        <form method="post" action="/Item/Process">
            <input type="number" step="0.1" name="weight" placeholder="Enter weight..." required />
            <button type="submit">Process Item</button>
        </form>
    </div>
</div>

<style>
.container {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 80vh;
}

.card {
    padding: 30px;
    border-radius: 10px;
    box-shadow: 0 0 10px rgba(0,0,0,0.1);
    text-align: center;
    width: 300px;
    background: white;
}

input {
    width: 100%;
    padding: 10px;
    margin: 15px 0;
}

button {
    padding: 10px 20px;
    background: #007bff;
    color: white;
    border: none;
    cursor: pointer;
}

button:hover {
    background: #0056b3;
}
</style>